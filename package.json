{
  "name": "scaffold-cli",
  "version": "1.0.0",
  "description": "A command-line tool for quickly generating project templates",
  "bin": {
    "scaffold": "./bin/scaffold.js"
  },
  "main": "lib/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.js"],
    "collectCoverageFrom": [
      "lib/**/*.js",
      "!lib/prompt.js"
    ]
  },
  "keywords": [
    "scaffold",
    "template",
    "cli",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  }
}
